<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .btn {
            background-color: #000;
            color: #fff;
            border-radius: 5px;
        }
        .btn a{
            display: inline-block;
            color: #fff;
            text-decoration: none;
            padding: 8px 12px;
        }
        footer {
            margin-top: 20px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Forgot Password</h1>
        <h2>Hello <%= name %></h2>
        <p>We have received a request to reset your password. Click the button below to reset your password (Button is valid for only 10 minutes).</p>
        <button class="btn">
        <a href="<%= resetPasswordUrl %>" target="_blank">Reset Password</a>
        </button>
        <p>
            <b>If you did not request for password reset, please ignore this email.</b>
        </p>
    </div>
    <footer>
        <p>© 2025 Tour Management System. All rights reserved.</p>
    </footer>
</body>

</html>